APP_NAME=StackEarnx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=StackEarnx
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

FILESYSTEM_DISK=public

# Admin account created on first seeder run
ADMIN_NAME="Settlimax Admin"
ADMIN_EMAIL=admin@settlimax.com
ADMIN_PASSWORD=Admin@1234

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
